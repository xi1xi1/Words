# =============================================================================
# 背了么 / beileme — 环境变量示例（占位值，勿填真实密钥）
# =============================================================================
# 使用方式：
#   1. 复制本文件为项目根目录的 `.env`（例如：copy .env.example .env）
#   2. 将下方占位值替换为你本地的强密码与密钥
#   3. `.env` 已被 .gitignore 忽略，切勿提交到 Git
#
# Spring Boot 会将环境变量按宽松绑定映射到配置项，例如：
#   JWT_SECRET -> jwt.secret
#   ARK_API_KEY -> ark.api-key
#   APP_CORS_ALLOWED_ORIGINS -> app.cors.allowed-origins
#   APP_CORS_ALLOW_ALL -> app.cors.allow-all（true 时允许任意 Origin，仅建议本地调试）
#   APP_CORS_MERGE_LOCALHOST_PATTERNS -> app.cors.merge-localhost-patterns（默认 true，与自定义白名单合并 localhost/127）
# 具体以当前代码 @Value / application 为准。
# =============================================================================

# --- Docker Compose（根目录 `docker compose` 会读取 `.env` 做变量替换）---
# 适用于 docker-compose.yml、compose.yaml、compose.prod.yaml（除 prod 中 MySQL root 另见 secrets）
# MySQL 容器 root 密码；开发 / 默认编排中后端 JDBC 密码与此相同
MYSQL_ROOT_PASSWORD=please-set-a-strong-mysql-password

# 可选：库名、端口（不设置则使用 compose 内默认值）
MYSQL_DATABASE=beileme
MYSQL_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=8080

# compose.prod.yaml：宿主机访问后端的端口（映射到容器 8080；与前端默认 80 错开，避免冲突）
# BACKEND_PUBLISH_PORT=8080

# compose.prod.yaml：宿主机访问 Flutter Web（Nginx 容器内 8080 → 宿主机端口，默认 80）
# FRONTEND_PUBLISH_PORT=80

# compose.prod.yaml / deploy.sh：GHCR 预构建镜像（.github/workflows/docker.yml 推送，全小写路径）
# BACKEND_IMAGE=ghcr.io/your-github-username/your-repo-name/backend:latest
# FRONTEND_IMAGE=ghcr.io/your-github-username/your-repo-name/frontend:latest

# docker-compose.yml / compose.yaml：本机构建前端时映射的宿主机端口（默认 8081，避免与 BACKEND_PORT 8080 混淆）
# FRONTEND_PORT=8081

# compose.prod.yaml：MySQL root 密码文件 secrets/mysql_root_password.txt（单行，见 secrets/README.md）

# 后端容器 Spring Profile（compose 默认 docker）
SPRING_PROFILES_ACTIVE=docker

# --- Spring Boot / 本地运行（与 docker-compose 中 backend 注入项对齐）---
# JDBC（本地直连宿主机 MySQL 时，将 host 改为 localhost 等）
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/beileme?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_general_ci
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=please-set-a-strong-mysql-password

# JWT（JwtUtil：jwt.secret；须 UTF-8 下至少 32 字节以满足 HS256）
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_BYTES_LONG
JWT_EXPIRATION=86400000

# CORS（WebConfig：app.cors.allowed-origins；逗号分隔的 Origin 模式，见 Spring allowedOriginPatterns）
# 白名单匹配的是请求头 Origin（浏览器里打开的前端页面地址），不是「你填写的 API 地址」的主机。
# 例：页面 http://localhost:58867、API http://172.20.10.2:8080 时，Origin 仍是 localhost，须含 http://localhost:*
# 若只配了 http://172.20.10.2:*，默认仍会合并 localhost/127 模式（见 APP_CORS_MERGE_LOCALHOST_PATTERNS）；生产要严格白名单可关
# 本地 Flutter Web 端口不固定，建议包含 http://localhost:* 与 http://127.0.0.1:*；未设置时后端有开发默认值
# 生产环境写明确 Origin，例如：https://app.example.com
# APP_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,https://app.example.com
# APP_CORS_MERGE_LOCALHOST_PATTERNS=false
# APP_CORS_ALLOW_ALL=true

# Actuator（与 application.properties 一致时可不设；Compose 中为 health）
# SPRING_MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health

# 日志级别（compose 示例中有此项）
# LOGGING_LEVEL_COM_ZYCHEN_BACKEND=INFO

# --- 火山方舟 Ark（AIServiceImpl：ark.base-url / ark.api-key / ark.endpoint-id）---
# 未配置 api-key 时 AI 相关接口不可用；base-url 有代码内公开默认值，一般无需改
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_API_KEY=your-volcengine-ark-api-key-placeholder
ARK_ENDPOINT_ID=your-ark-endpoint-id-placeholder
