<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name"
                    defaultValue="beileme-backend"/>
    <springProperty scope="context" name="LOG_LEVEL_ROOT" source="logging.level.root"
                    defaultValue="INFO"/>
    <!-- 作业要求字段：time、level、message、module（logger 重命名）；仅控制台 JSON（Docker/Railway 采集 stdout） -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <fieldNames>
                <timestamp>time</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
                <logger>module</logger>
            </fieldNames>
            <customFields>{"app":"${APP_NAME}"}</customFields>
        </encoder>
    </appender>

    <!-- 包级别由 application.yml 的 logging.level.* 控制 -->
    <root level="${LOG_LEVEL_ROOT}">
        <appender-ref ref="CONSOLE_JSON"/>
    </root>

</configuration>
